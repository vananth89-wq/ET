# ─────────────────────────────────────────────────────────────
# Prowess Expense Tracker — Environment Variables
# ─────────────────────────────────────────────────────────────
# Copy this file to .env.local and fill in your values.
# .env.local is gitignored — never commit real keys.
# ─────────────────────────────────────────────────────────────

# Supabase — Settings → General (Project URL)
VITE_SUPABASE_URL=https://your-project-id.supabase.co

# Supabase — Settings → API Keys → Publishable key (starts with sb_publishable_)
# This is safe to use in the browser. Do NOT use the Secret key here.
VITE_SUPABASE_ANON_KEY=sb_publishable_your-key-here
